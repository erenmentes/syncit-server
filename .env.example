PORT=3000

# Option A (recommended): single URL
# Examples:
# - redis://localhost:6379
# - redis://:password@localhost:6379/0
# - rediss://user:password@host:6380/0
REDIS_URL=redis://localhost:6379

# Option B: host/port fields (used if REDIS_URL is not set)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Optional: prefix all keys with this value
REDIS_KEY_PREFIX=syncit:
